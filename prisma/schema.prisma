generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String

  companies    Company[]

  createdAt    DateTime @default(now())
}

model Company {
  id        String   @id @default(cuid())
  name      String
  gstin     String?

  ownerId   String
  owner     User @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
}