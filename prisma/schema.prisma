generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  
  currentCompanyId String?
  
  companies     Company[]

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  gstin     String?

  ownerId   String
  owner     User @relation(fields: [ownerId], references: [id])
  ledgers Ledger[]
  stockItems StockItem[]
  salesVouchers SalesVoucher[]
  PurchaseVoucher PurchaseVoucher[]


  createdAt DateTime @default(now())
}

model Ledger {
  id          String   @id @default(cuid())

  name        String
  groupName   String

  openingBal  Float    @default(0)

  companyId   String
  company     Company @relation(fields: [companyId], references: [id])

  createdAt   DateTime @default(now())
}

model StockItem {
  id          String   @id @default(cuid())

  name        String
  sku         String

  unit        String

  gstPercent  Float

  openingQty  Float @default(0)
  openingRate Float @default(0)
  
  
   currentQty   Float @default(0)

  companyId   String
  company     Company @relation(fields: [companyId], references: [id])

  purchaseItems PurchaseItem[]
  
  createdAt   DateTime @default(now())
}

model SalesVoucher {
  id          String   @id @default(cuid())

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  voucherNo   Int
  partyName   String

  totalAmount Float
  items       SalesItem[]

  createdAt   DateTime @default(now())
}

model PurchaseVoucher {
  id             String   @id @default(cuid())
  voucherNo      Int
  partyName      String
  totalAmount    Float

  companyId      String
  company        Company @relation(fields: [companyId], references: [id])
  
  items PurchaseItem[]

  createdAt      DateTime @default(now())
}

model SalesItem {
  id          String @id @default(cuid())

  voucherId   String
  voucher     SalesVoucher @relation(fields: [voucherId], references: [id])

  itemName    String
  qty         Float
  rate        Float
  amount      Float
}

model PurchaseItem {
  id          String @id @default(cuid())

  voucherId   String
  voucher     PurchaseVoucher @relation(fields: [voucherId], references: [id])

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  qty         Float
  rate        Float
  amount      Float
}